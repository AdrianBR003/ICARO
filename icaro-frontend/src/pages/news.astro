---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import NavBar from "@/components/NavBar.astro";
import TopUtility from "@/components/TopUtility.astro";
import "@/styles/index.css";
import imagedefault from "@/assets/imagedefault.webp";
import imagedefault2 from "@/assets/epslportada.webp";
import imagedefault3 from "@/assets/imageexample.webp";

const researchProjects = [
  {
    id: 1,
    title: "Procesamiento de Señales 5G",
    collaborators: ["Dr. Juan Pérez", "Dra. María López", "Dr. Carlos Ruiz"],
    description:
      "Sound event localization and detection (SELD) is the combined task of identifying the temporal onset and offset of a sound event, tracking the spatial location when active, and further associating a textual label describing the sound event. Our work on SELD was recently published in the reputed journal of selected topics in signal processing (JSTSP). The proposed method was compared with two sound event detection, three direction-of-arrival estimations, and one SELD baselines. The results showed that the proposed method is generic and applicable to any array structures, robust to unseen DOA values, reverberation, and low SNR scenarios. All the datasets used for evaluation and the code has been publicly released to support open research.",
    publicationDate: "2023-01-15",
    image: imagedefault.src,
    link: "/research/5g-signal-processing",
  },
  {
    id: 2,
    title: "Machine Learning en Telecomunicaciones",
    collaborators: [
      "Dra. Ana García",
      "Dr. Luis Martínez",
      "Dr. Roberto Sánchez",
    ],
    description:
      "Sound event localization and detection (SELD) is the combined task of identifying the temporal onset and offset of a sound event, tracking the spatial location when active, and further associating a textual label describing the sound event. Our work on SELD was recently published in the reputed journal of selected topics in signal processing (JSTSP). The proposed method was compared with two sound event detection, three direction-of-arrival estimations, and one SELD baselines. The results showed that the proposed method is generic and applicable to any array structures, robust to unseen DOA values, reverberation, and low SNR scenarios. All the datasets used for evaluation and the code has been publicly released to support open research.",
    publicationDate: "2023-02-10",
    image: imagedefault2.src,
    link: "/research/ml-telecom",
  },
  {
    id: 3,
    title: "Comunicaciones Cuánticas",
    collaborators: [
      "Dr. Fernando Díaz",
      "Dra. Elena Torres",
      "Dr. Javier Jiménez",
    ],
    description:
      "Sound event localization and detection (SELD) is the combined task of identifying the temporal onset and offset of a sound event, tracking the spatial location when active, and further associating a textual label describing the sound event. Our work on SELD was recently published in the reputed journal of selected topics in signal processing (JSTSP). The proposed method was compared with two sound event detection, three direction-of-arrival estimations, and one SELD baselines. The results showed that the proposed method is generic and applicable to any array structures, robust to unseen DOA values, reverberation, and low SNR scenarios. All the datasets used for evaluation and the code has been publicly released to support open research.",
    publicationDate: "2023-01-15",
    image: imagedefault3.src,
    link: "/research/quantum-comms",
  },
  {
    id: 4,
    title: "IoT para Smart Cities",
    collaborators: [
      "Dra. Carmen Vargas",
      "Dr. Antonio Mora",
      "Dr. Miguel Ángel Reyes",
    ],
    description:
      "Implementación de redes de sensores interconectados para optimizar servicios urbanos como transporte, energía y gestión de residuos.",
    publicationDate: "2023-04-20",
    image: "/images/iot-smart-city.jpg",
    link: "/research/iot-smart-cities",
  },
];
---

<BaseLayout>
  <section class="max-w-full bg-white shadow-md rounded-lg">
    <TopUtility />
    <Header />
  </section>
  <section class="mt-10 max-w-full bg-white shadow-md">
    <NavBar />
  </section>

  <section class="w-full px-4 mx-auto max-w-custom">
    <div class="text-center my-10">
      <div class="mb-8 relative inline-block w-full text-center py-2">
        <h2 class="text-2xl font-bold text-[#231F20]">News</h2>
        <span
          class="absolute left-1/2 bottom-0 w-20 h-1 bg-[#006D38] -translate-x-1/2"
        ></span>
      </div>
      <p class="text-lg text-gray-600 mx-auto max-w-2xl">
        Nuestro grupo de investigación se especializa en el desarrollo de
        tecnologías avanzadas de telecomunicación y procesamiento de señales.
      </p>
    </div>

    <div class="grid gap-10">
      {
        researchProjects.map((project) => (
          <div class="bg-white rounded-xl shadow-lg overflow-hidden transition-all duration-300 research-card group relative">
            <div class="absolute top-0 right-0 z-10 bg-[#1D293D] text-white text-xs px-3 py-2 rounded-bl-lg flex items-center">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-3 w-3 mr-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
              <span>{project.publicationDate}</span>
            </div>

            <div class="flex flex-col lg:flex-row">
              <div class="lg:w-2/5 flex-shrink-0 flex items-center justify-center bg-white">
                <div class="max-100 lg:h-72 overflow-hidden flex items-center justify-center p-4">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="max-w-full max-h-full object-contain rounded-lg"
                  />
                </div>
              </div>

              <div
                class="lg:w-3/5 p-8 lg:p-10 relative flex flex-col"
                style="min-height: 288px;"
              >
                <h2 class="text-2xl font-bold text-[#1D293D] mb-4 relative text-center w-full">
                  {project.title}
                  <span class="absolute left-1/2 -bottom-2 w-0 h-1 bg-[#006D38] transition-all duration-300 group-hover:w-70 -translate-x-1/2" />
                </h2>

                <div class="mb-5 mt-2">
                  <p class="text-gray-600 mb-6 leading-relaxed text-justify flex-grow">
                    {project.description}
                  </p>
                </div>

                <div class="mt-auto flex justify-end">
                  <a
                    href={project.link}
                    class="px-6 py-3 bg-white text-[#006D38] border border-[#006D38] rounded-lg font-medium flex items-center 
          transition-all duration-300 transform hover:bg-[#006D38] hover:text-white hover:scale-105"
                  >
                    Leer más
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5 ml-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .research-card {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .research-card {
      margin-left: -20px;
      margin-right: -20px;
    }
  }

  .max-w-custom {
    max-width: 1200px;
  }
</style>
